# Phoenix configuration. Copy to .env and adjust. SDK reads these at boot.
# Host ports avoid clashing with a local Postgres/Redis (see docker-compose.yml).
PORT=8080
DATABASE_URL=postgres://phoenix:phoenix@127.0.0.1:55432/phoenix?sslmode=disable
REDIS_URL=redis://127.0.0.1:63790/0
JWT_SECRET=dev-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
HEARTBEAT_INTERVAL=30s
RECONNECT_WINDOW=30s
